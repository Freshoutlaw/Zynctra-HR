/**
 * /frontend/.env.example
 * 
 * Copy this file to .env.local and configure for your environment.
 * NEVER commit actual secrets to version control.
 * Use secure secret management (AWS Secrets Manager, HashiCorp Vault, etc.)
 */

# Application Settings
REACT_APP_ENV=development
REACT_APP_VERSION=1.0.0
REACT_APP_COMPANY_NAME=Zynctra HR

# API Configuration
REACT_APP_API_URL=http://localhost:8080/api
REACT_APP_API_TIMEOUT=30000
REACT_APP_WEBSOCKET_URL=ws://localhost:8080/ws

# Security Settings
REACT_APP_SESSION_TIMEOUT=1800000
REACT_APP_MFA_REQUIRED=true
REACT_APP_ENFORCE_HTTPS=true
REACT_APP_CSP_ENABLED=true

# Feature Flags
REACT_APP_ENABLE_AI_ASSISTANT=true
REACT_APP_ENABLE_SECURE_TERMINAL=true
REACT_APP_ENABLE_ANOMALY_DETECTION=true
REACT_APP_ENABLE_PAYROLL_EXPORTS=true

# Analytics & Monitoring
REACT_APP_SENTRY_DSN=https://your-sentry-key@sentry.io/project-id
REACT_APP_ANALYTICS_ENABLED=false
REACT_APP_LOG_LEVEL=error

# Tenant Configuration
REACT_APP_TENANT_ID=default
REACT_APP_DATA_RESIDENCY=US_EAST

# Groq LLM Configuration
REACT_APP_LLM_PROVIDER=groq
REACT_APP_GROQ_MODEL=mixtral-8x7b-32768

# Email Configuration
REACT_APP_SUPPORT_EMAIL=support@zynctra.com
REACT_APP_SALES_EMAIL=sales@zynctra.com













# ============================================================================
# ZYNCTRA FRONTEND - ENVIRONMENT CONFIGURATION
# 
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local - it's in .gitignore
# NEVER hardcode secrets in the frontend
# ============================================================================

# ============================================================================
# API CONFIGURATION
# ============================================================================

# Backend API URL
REACT_APP_API_URL=http://localhost:8080/api

# WebSocket URL for real-time features
REACT_APP_WEBSOCKET_URL=ws://localhost:8080/ws

# Request timeout in milliseconds
REACT_APP_REQUEST_TIMEOUT=30000

# ============================================================================
# PAYMENT GATEWAY (PAYSTACK)
# 
# Use ONLY public keys here
# Never use secret keys in frontend
# ============================================================================

# Paystack public key (get from dashboard)
REACT_APP_PAYSTACK_PUBLIC_KEY=pk_live_your_public_key_here

# Primary payment provider (paystack|stripe)
REACT_APP_PAYMENT_PROVIDER=paystack

# Allowed currencies for billing
REACT_APP_CURRENCIES=USD,NGN,EUR,GBP

# ============================================================================
# MONETIZATION & BILLING
# 
# Control billing behavior without code changes
# ============================================================================

# Enable monetization system
REACT_APP_MONETIZATION_ENABLED=false

# Free mode (all features available, no payment required)
# Set to true for launch phase, false when billing is active
REACT_APP_FREE_MODE=true

# Default plan for new users
REACT_APP_DEFAULT_PLAN=FREE

# Trial period in days
REACT_APP_TRIAL_DAYS=14

# Require payment method on signup
REACT_APP_REQUIRE_PAYMENT_METHOD=false

# ============================================================================
# SUPABASE CLOUD DATABASE
# 
# Non-sensitive cloud database configuration
# Stores user profiles, billing records, audit logs
# ============================================================================

# Supabase project URL
REACT_APP_SUPABASE_URL=https://pruhbzjeueinnbruvatv.supabase.co

# Supabase public anon key (not a secret)
REACT_APP_SUPABASE_ANON_KEY=sb_publishable_atMOOTuBaCb7b0Ni97bEPw_9roU-wTV

# ============================================================================
# AUTHENTICATION
# ============================================================================

# Session timeout in milliseconds (30 minutes default)
REACT_APP_SESSION_TIMEOUT=1800000

# Token refresh interval in milliseconds (15 minutes default)
REACT_APP_TOKEN_REFRESH_INTERVAL=900000

# Enable automatic logout on token expiration
REACT_APP_AUTO_LOGOUT=true

# ============================================================================
# ANALYTICS & MONITORING
# 
# Error tracking and analytics (optional)
# ============================================================================

# Sentry error tracking (optional)
REACT_APP_SENTRY_DSN=

# Enable analytics
REACT_APP_ANALYTICS_ENABLED=false

# Google Analytics ID (optional)
REACT_APP_GA_ID=

# ============================================================================
# LOGGING & DEBUG
# ============================================================================

# Log level: debug|info|warn|error
REACT_APP_LOG_LEVEL=error

# Enable development mode logging
REACT_APP_DEBUG=false

# ============================================================================
# UI & THEMING
# ============================================================================

# Default theme: light|dark|system
REACT_APP_DEFAULT_THEME=system

# Enable animations
REACT_APP_ANIMATIONS_ENABLED=true

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable/disable specific features without code changes
REACT_APP_FEATURE_TERMINAL=false
REACT_APP_FEATURE_ANALYTICS=true
REACT_APP_FEATURE_PAYROLL=false
REACT_APP_FEATURE_COMPLIANCE=false

# ============================================================================
# SECURITY
# ============================================================================

# Content Security Policy settings
REACT_APP_CSP_ENABLED=true

# Enable CORS credentials
REACT_APP_CORS_CREDENTIALS=true

# ============================================================================
# BUILD & DEPLOYMENT
# ============================================================================

# Build mode: production|development|staging
NODE_ENV=development

# Enable source maps in production
GENERATE_SOURCEMAP=false

# ============================================================================
# IMPORTANT NOTES
# ============================================================================

# 1. NEVER hardcode API keys, database passwords, or secrets
# 2. NEVER commit .env.local to version control
# 3. Use environment-specific .env files for different deployments
# 4. Rotate secrets regularly
# 5. Use backend for sensitive operations (auth, payments, database)
# 6. Frontend can only see public/non-sensitive config
